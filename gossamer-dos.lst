  1103 00000622 BFDC00                      mov di, 220
  1104 00000625 B40F                        mov ah, 0x0F           ; white on black
  1105 00000627 BE[9006]                    mov si, splash_title
  1106 0000062A E83000                      call .write_splash_str
  1107                                  
  1108                                      ; "640K conventional memory" at row 3, col 28 (offset = (3*80+28)*2 = 536)
  1109 0000062D BF1802                      mov di, 536
  1110 00000630 BE[A306]                    mov si, splash_mem
  1111 00000633 E82700                      call .write_splash_str
  1112                                  
  1113                                      ; Update cursor position in BDA to row 5 (below splash)
