  1119                                      ; --- Boot status messages via INT 10h ---
  1120 00000645 FB                          sti
  1121 00000646 BE[BC06]                    mov si, msg_ivt
  1122 00000649 E82B00                      call bios_print
  1123 0000064C BE[C506]                    mov si, msg_boot
  1124 0000064F E82500                      call bios_print
  1125                                  
  1126                                      ; --- Jump to DOS kernel ---
  1127                                      ; KERNEL.SYS is pre-loaded at 0060:0000 by the transpiler.
  1128                                      ; Kernel expects BL = boot drive (0x00 = A:)
  1129 00000652 31C0                        xor ax, ax
  1130 00000654 8ED8                        mov ds, ax
  1131 00000656 B300                        mov bl, 0x00
  1132 00000658 EA00006000                  jmp KERNEL_SEG:0x0000
  1133                                  
  1134                                  ; --- Write null-terminated string to VGA at DS:DI ---
  1135                                  ; AH = attribute byte (preserved). DS=VGA_SEG on entry.
  1136                                  ; SI points into BIOS ROM (CS segment). Swaps DS to read.
  1137                                  .write_splash_str:
  1138 0000065D 53                          push bx
  1139 0000065E 8CDB                        mov bx, ds             ; save VGA segment in BX
  1140                                  .wss_loop:
  1141                                      ; Read byte from CS:SI
  1142 00000660 0E                          push cs
  1143 00000661 1F                          pop ds
  1144 00000662 8A04                        mov al, [si]
  1145 00000664 8EDB                        mov ds, bx             ; restore DS = VGA segment
  1146 00000666 84C0                        test al, al
  1147 00000668 740B                        jz .wss_done
  1148 0000066A 8805                        mov [di], al
  1149 0000066C 886501                      mov [di+1], ah
  1150 0000066F 83C702                      add di, 2
  1151 00000672 46                          inc si
  1152 00000673 EBEB                        jmp short .wss_loop
  1153                                  .wss_done:
  1154 00000675 5B                          pop bx
  1155 00000676 C3                          ret
  1156                                  
  1157                                  ; --- BIOS print: print null-terminated string at CS:SI via INT 10h ---
  1158                                  bios_print:
  1159 00000677 50                          push ax
  1160 00000678 53                          push bx
  1161                                  .bp_loop:
  1162 00000679 1E                          push ds
  1163 0000067A 0E                          push cs
  1164 0000067B 1F                          pop ds
  1165 0000067C 8A04                        mov al, [si]
  1166 0000067E 1F                          pop ds
  1167 0000067F 84C0                        test al, al
  1168 00000681 740A                        jz .bp_done
  1169 00000683 B40E                        mov ah, 0x0E
  1170 00000685 BB0700                      mov bx, 0x0007
  1171 00000688 CD10                        int 0x10
  1172 0000068A 46                          inc si
  1173 0000068B EBEC                        jmp short .bp_loop
  1174                                  .bp_done:
  1175 0000068D 5B                          pop bx
  1176 0000068E 58                          pop ax
  1177 0000068F C3                          ret
