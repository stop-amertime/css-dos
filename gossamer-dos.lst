  1195 000006D9 00                          db 0x00                ; byte 3: submodel
  1196 000006DA 00                          db 0x00                ; byte 4: BIOS revision
  1197 000006DB 00                          db 0x00                ; byte 5: feature byte 1 (no special hw)
  1198                                  ;       |||||||`-- dual bus
  1199                                  ;       ||||||`-- Micro Channel
  1200                                  ;       |||||`-- EBDA allocated
  1201                                  ;       ||||`-- wait for event supported
  1202                                  ;       |||`-- INT 15h/4Fh called on INT 09h
  1203                                  ;       ||`-- RTC installed
  1204                                  ;       |`-- 2nd PIC installed
