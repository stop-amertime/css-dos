  1206 000006DC 00                          db 0x00                ; byte 6: feature byte 2
  1207 000006DD 00                          db 0x00                ; byte 7: feature byte 3
  1208 000006DE 00                          db 0x00                ; byte 8: feature byte 4
  1209 000006DF 00                          db 0x00                ; byte 9: feature byte 5
  1210                                  .size equ $ - .bytes
