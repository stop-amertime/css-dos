# Builder output - cabinets land here by default (see builder/build.mjs).
out/
output/

# Cabinets at repo root and their sidecars - built ad-hoc, ephemeral.
# The bench harness uses tests/bench/cache/ for its own cabinets.
/*.css
/*.meta.json
/*.disk.bin
/*.kernel.bin
/*.bios.bin

# Bench harness cabinet cache (ephemeral; ensureFresh manages it).
tests/bench/cache/

# tests/harness/results/ accumulates per-run fast-shot PNGs and
# conformance JSONs. Latest is useful; the per-session backlog isn't.
tests/harness/results/*.png
tests/harness/results/conformance-*.json

# Scratch builds used during testing - any top-level file starting with tmp-.
tmp-*
tmp/

# Various parts of the docs are uninteresting for release
docs/archives
docs/benches
docs/logbook
docs/plans
docs/reference


# Cabinets/HTML generated by ad-hoc runs into tests/ (conformance fixtures
# live in tests/ as .com/.asm; .css/.html under tests/ are always build output).
tests/*.css
tests/*.html

# Compiled binaries and listings
*.bin
*.lst
*.start
*.o
!bios/gossamer/gossamer.bin
!bios/gossamer/gossamer.lst
!bios/corduroy/cga-8x8.bin
!bios/corduroy/vga-dac.bin
!player/fonts/vga-8x16.bin
!dos/msdos4/bin/msboot.bin

# Build outputs
bios/corduroy/build/
bios/corduroy/bios.map

# Node
node_modules/
dist/

# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# User-dropped reference images / assets (not part of the repo)
icons/assets/

# IDE
.idea/
.vscode/
.serena/
*.swp
*.swo

# Playwright debug artifacts
.playwright-mcp/

# Trace / conformance artifacts (JSON dumps from ref emulators, etc.)
ref-trace.json
*-trace.json
trace-*.json

# Claude/editor state
.claude/

# Disk images and archives
*.img
*.zip

# Builder cache
.cache/

# Ephemeral planning artifacts from superpowers workflow
docs/superpowers/
entry.err

# Raw benchmark JSON dumps - machine output kept only as local provenance
# while iterating on perf. Headline numbers live in docs/logbook/STATUS.md.
docs/benches/

# Cart contents are source, never build output - nothing under carts/ may
# be ignored. (Last-match wins: this beats *.bin/*.img/*.zip above. The
# *.bin rule silently swallowed carts/0windows101/WIN100.BIN and the live
# site's Windows build failed for the lack of it, 2026-07-13.) Must stay LAST.
!carts/**
