{"nodes":[{"kind":"block","code":"/* ModR/M instruction length delta: how many extra bytes does the ModR/M consume?\n   mod=00, rm=110: +2 (direct address)\n   mod=01: +1 (8-bit displacement)\n   mod=10: +2 (16-bit displacement)\n   mod=11: +0 (register)\n   otherwise: +0 */"},{"kind":"decl","code":"@function --modrmLen(--mod <integer>, --rm <integer>) returns <integer> {","children":[{"kind":"decl","code":"result:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--mod: 3):","children":[{"kind":"value","code":"0;"}]},{"kind":"branch","code":"style(--mod: 1):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--mod: 2):","children":[{"kind":"value","code":"2;"}]},{"kind":"branch","code":"style(--mod: 0) and style(--rm: 6):","children":[{"kind":"value","code":"2;"}]},{"kind":"branch","code":"else:","children":[{"kind":"value","code":"0"}]}],"trailer":");"}],"folded":true}],"trailer":"}","folded":true},{"kind":"block","code":"/* Effective address offset (16-bit, before adding segment).\n   Inputs: mod, rm, and the instruction bytes after ModR/M (disp8/disp16).\n   disp8 = sign-extended byte at queue[2]\n   disp16 = word at queue[2..3] */"},{"kind":"decl","code":"@function --eaOffset(--mod <integer>, --rm <integer>,\n                     --bx <integer>, --si <integer>, --di <integer>, --bp <integer>,\n                     --disp8 <integer>, --disp16 <integer>) returns <integer> {","children":[{"kind":"decl","code":"--disp:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--mod: 1):","children":[{"kind":"value","code":"var(--disp8);"}]},{"kind":"branch","code":"style(--mod: 2):","children":[{"kind":"value","code":"var(--disp16);"}]},{"kind":"branch","code":"else:","children":[{"kind":"value","code":"0"}]}],"trailer":");"}],"folded":true},{"kind":"block","code":"result: --lowerBytes(if(\n    style(--mod: 0) and style(--rm: 6): var(--disp16);\n    style(--rm: 0): calc(var(--bx) + var(--si) + var(--disp));\n    style(--rm: 1): calc(var(--bx) + var(--di) + var(--disp));\n    style(--rm: 2): calc(var(--bp) + var(--si) + var(--disp));\n    style(--rm: 3): calc(var(--bp) + var(--di) + var(--disp));\n    style(--rm: 4): calc(var(--si) + var(--disp));\n    style(--rm: 5): calc(var(--di) + var(--disp));\n    style(--rm: 6): calc(var(--bp) + var(--disp));\n    style(--rm: 7): calc(var(--bx) + var(--disp));\n  else: 0), 16);"}],"trailer":"}","folded":true},{"kind":"block","code":"/* Default segment for a ModR/M address: SS for BP-based, DS for everything else.\n   Returns seg*16 for direct addition to EA offset. */"},{"kind":"decl","code":"@function --defaultSeg(--mod <integer>, --rm <integer>,\n                       --ds <integer>, --ss <integer>) returns <integer> {","children":[{"kind":"decl","code":"result:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--mod: 3):","children":[{"kind":"value","code":"0;"}]},{"kind":"branch","code":"style(--rm: 2):","children":[{"kind":"value","code":"calc(var(--ss) * 16);"}]},{"kind":"branch","code":"style(--rm: 3):","children":[{"kind":"value","code":"calc(var(--ss) * 16);"}]},{"kind":"branch","code":"style(--mod: 0) and style(--rm: 6):","children":[{"kind":"value","code":"calc(var(--ds) * 16);"}]},{"kind":"branch","code":"style(--rm: 6):","children":[{"kind":"value","code":"calc(var(--ss) * 16);"}]},{"kind":"branch","code":"else:","children":[{"kind":"value","code":"calc(var(--ds) * 16)"}]}],"trailer":");"}],"folded":true}],"trailer":"}","folded":true},{"kind":"block","code":"/* Read a register by index (word mode).\n   reg: 0=AX, 1=CX, 2=DX, 3=BX, 4=SP, 5=BP, 6=SI, 7=DI */"},{"kind":"decl","code":"@function --getReg16(--r <integer>,\n                     --ax <integer>, --cx <integer>, --dx <integer>, --bx <integer>,\n                     --sp <integer>, --bp <integer>, --si <integer>, --di <integer>) returns <integer> {","children":[{"kind":"decl","code":"result:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--r: 0):","children":[{"kind":"value","code":"var(--ax);"}]},{"kind":"branch","code":"style(--r: 1):","children":[{"kind":"value","code":"var(--cx);"}]},{"kind":"branch","code":"style(--r: 2):","children":[{"kind":"value","code":"var(--dx);"}]},{"kind":"branch","code":"style(--r: 3):","children":[{"kind":"value","code":"var(--bx);"}]},{"kind":"branch","code":"style(--r: 4):","children":[{"kind":"value","code":"var(--sp);"}]},{"kind":"branch","code":"style(--r: 5):","children":[{"kind":"value","code":"var(--bp);"}]},{"kind":"branch","code":"style(--r: 6):","children":[{"kind":"value","code":"var(--si);"}]},{"kind":"branch","code":"style(--r: 7):","children":[{"kind":"value","code":"var(--di);"}]},{"kind":"branch","code":"else:","children":[{"kind":"value","code":"0"}]}],"trailer":");"}],"folded":true}],"trailer":"}","folded":true},{"kind":"block","code":"/* Read a register by index (byte mode).\n   reg: 0=AL, 1=CL, 2=DL, 3=BL, 4=AH, 5=CH, 6=DH, 7=BH */"},{"kind":"decl","code":"@function --getReg8(--r <integer>,\n                    --al <integer>, --cl <integer>, --dl <integer>, --bl <integer>,\n                    --ah <integer>, --ch <integer>, --dh <integer>, --bh <integer>) returns <integer> {","children":[{"kind":"decl","code":"result:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--r: 0):","children":[{"kind":"value","code":"var(--al);"}]},{"kind":"branch","code":"style(--r: 1):","children":[{"kind":"value","code":"var(--cl);"}]},{"kind":"branch","code":"style(--r: 2):","children":[{"kind":"value","code":"var(--dl);"}]},{"kind":"branch","code":"style(--r: 3):","children":[{"kind":"value","code":"var(--bl);"}]},{"kind":"branch","code":"style(--r: 4):","children":[{"kind":"value","code":"var(--ah);"}]},{"kind":"branch","code":"style(--r: 5):","children":[{"kind":"value","code":"var(--ch);"}]},{"kind":"branch","code":"style(--r: 6):","children":[{"kind":"value","