anch","code":"style(--prefixLen: 1):","children":[{"kind":"value","code":"var(--raw5);"}]},{"kind":"branch","code":"else:","children":[{"kind":"value","code":"var(--raw6)"}]}],"trailer":");"}],"folded":true},{"kind":"decl","code":"--q5:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--prefixLen: 0):","children":[{"kind":"value","code":"var(--raw5);"}]},{"kind":"branch","code":"style(--prefixLen: 1):","children":[{"kind":"value","code":"var(--raw6);"}]},{"kind":"branch","code":"else:","children":[{"kind":"value","code":"var(--raw7)"}]}],"trailer":");"}],"folded":true},{"kind":"block","code":"/* Opcode (first non-prefix byte) */"},{"kind":"block","code":"--opcode: var(--q0);"},{"kind":"block","code":"/* d and w bits from opcode */"},{"kind":"block","code":"--dBit: --rightShift(--and(var(--opcode), 2), 1);"},{"kind":"block","code":"--wBit: --and(var(--opcode), 1);"}],"next":null}