{"nodes":[{"kind":"section","label":"instruction fetch","code":"/* --- instruction fetch --- */","folded":true,"children":[{"kind":"block","code":"/* Raw fetch: up to 8 bytes from CS:IP (enough for 2 prefix + 6-byte instruction) */"},{"kind":"decl","code":"--csBase:","children":[{"kind":"value","code":"calc(var(--__1CS) * 16);"}]},{"kind":"decl","code":"--ipAddr:","children":[{"kind":"value","code":"calc(var(--csBase) + var(--__1IP));"}]},{"kind":"decl","code":"--raw0:","children":[{"kind":"value","code":"--readMem(var(--ipAddr));"}]},{"kind":"decl","code":"--raw1:","children":[{"kind":"value","code":"--readMem(calc(var(--ipAddr) + 1));"}]},{"kind":"decl","code":"--raw2:","children":[{"kind":"value","code":"--readMem(calc(var(--ipAddr) + 2));"}]},{"kind":"decl","code":"--raw3:","children":[{"kind":"value","code":"--readMem(calc(var(--ipAddr) + 3));"}]},{"kind":"decl","code":"--raw4:","children":[{"kind":"value","code":"--readMem(calc(var(--ipAddr) + 4));"}]},{"kind":"decl","code":"--raw5:","children":[{"kind":"value","code":"--readMem(calc(var(--ipAddr) + 5));"}]},{"kind":"decl","code":"--raw6:","children":[{"kind":"value","code":"--readMem(calc(var(--ipAddr) + 6));"}]},{"kind":"decl","code":"--raw7:","children":[{"kind":"value","code":"--readMem(calc(var(--ipAddr) + 7));"}]}]},{"kind":"section","label":"prefix detection","code":"/* --- prefix detection --- */","folded":true,"lazy":{"ref":"cpu/000","count":11}},{"kind":"section","label":"instruction queue","code":"/* --- instruction queue --- */","folded":true,"lazy":{"ref":"cpu/001","count":12}},{"kind":"section","label":"ModR/M & effective address","code":"/* --- ModR/M & effective address --- */","folded":true,"lazy":{"ref":"cpu/002","count":17}},{"kind":"section","label":"immediates & operand reads","code":"/* --- immediates & operand reads --- */","folded":true,"children":[{"kind":"block","code":"/* Immediate values after ModR/M (position depends on modrmExtra).\n     immOff = prefixLen + 2 + modrmExtra (offset