-step) state --- */","folded":true,"children":[{"kind":"block","code":"/* TF (Trap Flag) single-step: 8086 fires INT 1 AFTER the instruction completes.\n     --_tfPending: set to 1 when current FLAGS has TF=1 (latches the request).\n     --_tf: fires INT 1 on the NEXT tick by reading __1_tfPending.\n     This way the instruction executes normally, then INT 1 fires on the following tick. */"},{"kind":"decl","code":"--_tfPending:","children":[{"kind":"value","code":"--bit(var(--flags), 8);"}]},{"kind":"decl","code":"--_tf:","children":[{"kind":"value","code":"var(--__1_tfPending);"}]},{"kind":"decl","code":"--_tfIP:","children":[{"kind":"value","code":"--read2(4);"}]},{"kind":"decl","code":"--_tfCS:","children":[{"kind":"value","code":"--read2(6);"}]}]},{"kind":"section","label":"unknown opcode flag","code":"/* --- unknown opcode flag --- */","folded":true,"children":[{"kind":"decl","code":"--unknownOp:","children":[{"kind":"if","code":"if(","trailer":");","lazy":{"ref":"cpu/004","count":248}}],"folded":true},{"kind":"decl","code":"--haltCode:","children":[{"kind":"value","code":"calc(var(--unknownOp) * var(--opcode));"}],"comment":"/* the offending opcode, 0 while running */"}]}],"next":null}