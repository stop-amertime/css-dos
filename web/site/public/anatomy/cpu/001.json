{"nodes":[{"kind":"block","code":"/* A byte is a prefix if it's one of: 0x26(ES) 0x2E(CS) 0x36(SS) 0x3E(DS) 0xF2(REPNE) 0xF3(REP)\n     We detect whether raw0 and raw1 are prefixes to compute prefixLen (0, 1, or 2). */"},{"kind":"decl","code":"--isPrefix0:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--raw0: 38):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw0: 46):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw0: 54):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw0: 62):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw0: 242):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw0: 243):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"else:","children":[{"kind":"value","code":"0"}]}],"trailer":");"}],"folded":true},{"kind":"decl","code":"--isPrefix1:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--isPrefix0: 0):","children":[{"kind":"value","code":"0;"}]},{"kind":"branch","code":"style(--raw1: 38):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw1: 46):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw1: 54):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw1: 62):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw1: 242):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--raw1: 243):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"else:","children":[{"kind":"value","code":"0"}]}],"trailer":");"}],"folded":true},{"kind":"block","code":"--prefixLen: calc(var(--isPrefix0) + var(--isPrefix1));"},{"kind":"block","code":"/* Segment override: check prefix bytes for 0x26/0x2E/0x36/0x3E.\n     Value is the segment register * 16, or 0 for \"no override\".\n     Check raw0 first, then raw1 (later prefix wins, matching 8086 behavior). */"},{"kind":"decl","code":"--segOverride:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--isPrefix1: 1) and style(--raw1: 38):","children":[{"kind":"value","code":"calc(var(--__1ES) * 16);"}]},{"kind":"branch","code":"style(--isPrefix1: 1) and style(--raw1: 46):","children":[{"kind":"value","code":"calc(var(--__1CS) * 16);"}]},{"kind":"branch","code":"style(--isPrefix1: 1) and style(--raw1: 54):","children":[{"kind":"value","code":"calc(var(--__1SS) * 16);"}]},{"kind":"branch","code":"style(--isPrefix1: 1) and style(--raw1: 62):","children":[{"kind":"value","code":"calc(var(--__1DS) * 16);"}]},{"kind":"branch","code":"style(--isPrefix0: 1) and style(--raw0: 38):","children":[{"kind":"value","code":"calc(var(--__1ES) * 16);"}]},{"kind":"branch","code":"style(--isPrefix0: 1) and style(--raw0: 46):","children":[{"kind":"value","code":"calc(var(--__1CS) * 16);"}]},{"kind":"branch","code":"style(--isPrefix0: 1) and style(--raw0: 54):","children":[{"kind":"value","code":"calc(var(--__1SS) * 16);"}]},{"kind":"branch","code":"style(--isPrefix0: 1) and style(--raw0: 62):","children":[{"kind":"value","code":"calc(var(--__1DS) * 16);"}]},{"kind":"branch","code":"else:","children":[{"kind":"value","code":"0"}]}],"trailer":");"}],"folded":true},{"kind":"block","code":"/* Flag: 1 if a segment override prefix is active */"},{"kind":"decl","code":"--hasSegOverride:","children":[{"kind":"if","code":"if(","children":[{"kind":"branch","code":"style(--isPrefix0: 1) and style(--raw0: 38):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--isPrefix0: 1) and style(--raw0: 46):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--isPrefix0: 1) and style(--raw0: 54):","children":[{"kind":"value","code":"1;"}]},{"kind":"branch","code":"style(--isPrefix0: 1) and style(--raw0: 62):","children":[{"kind":"value","code":"1;"}]},{"kin