  1204                                  ; System configuration table (returned by INT 15h AH=C0h)
  1205                                  ; Matches reference 8088_bios config_table layout.
  1206                                  ; ============================================================
  1207                                  config_table:
  1208 000006E2 0800                        dw .size               ; bytes 0-1: table size
  1209                                  .bytes:
  1210 000006E4 FE                          db 0xFE                ; byte 2: model byte (XT)
  1211 000006E5 00                          db 0x00                ; byte 3: submodel
  1212 000006E6 00                          db 0x00                ; byte 4: BIOS revision
  1213 000006E7 00                          db 0x00                ; byte 5: feature byte 1 (no special hw)
  1214                                  ;       |||||||`-- dual bus
  1215                                  ;       ||||||`-- Micro Channel
  1216                                  ;       |||||`-- EBDA allocated
  1217                                  ;       ||||`-- wait for event supported
  1218                                  ;       |||`-- INT 15h/4Fh called on INT 09h
  1219                                  ;       ||`-- RTC installed
  1220                                  ;       |`-- 2nd PIC installed
  1221                                  ;       `-- DMA ch3 used by HDD
  1222 000006E8 00                          db 0x00                ; byte 6: feature byte 2
  1223 000006E9 00                          db 0x00                ; byte 7: feature byte 3
  1224 000006EA 00                          db 0x00                ; byte 8: feature byte 4
  1225 000006EB 00                          db 0x00                ; byte 9: feature byte 5
  1226                                  .size equ $ - .bytes
