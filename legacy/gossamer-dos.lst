  1133 0000064C C606510005                  mov byte [video_cur_pos+1], 5   ; row
  1134                                  
  1135                                      ; --- Boot status messages via INT 10h ---
  1136 00000651 FB                          sti
  1137 00000652 BE[C806]                    mov si, msg_ivt
  1138 00000655 E82B00                      call bios_print
  1139 00000658 BE[D106]                    mov si, msg_boot
  1140 0000065B E82500                      call bios_print
  1141                                  
  1142                                      ; --- Jump to DOS kernel ---
  1143                                      ; KERNEL.SYS is pre-loaded at 0060:0000 by the transpiler.
  1144                                      ; Kernel expects BL = boot drive (0x00 = A:)
  1145 0000065E 31C0                        xor ax, ax
  1146 00000660 8ED8                        mov ds, ax
  1147 00000662 B300                        mov bl, 0x00
  1148 00000664 EA00006000                  jmp KERNEL_SEG:0x0000
  1149                                  
  1150                                  ; --- Write null-terminated string to VGA at DS:DI ---
  1151                                  ; AH = attribute byte (preserved). DS=VGA_SEG on entry.
  1152                                  ; SI points into BIOS ROM (CS segment). Swaps DS to read.
  1153                                  .write_splash_str:
  1154 00000669 53                          push bx
  1155 0000066A 8CDB                        mov bx, ds             ; save VGA segment in BX
  1156                                  .wss_loop:
  1157                                      ; Read byte from CS:SI
  1158 0000066C 0E                          push cs
  1159 0000066D 1F                          pop ds
  1160 0000066E 8A04                        mov al, [si]
  1161 00000670 8EDB                        mov ds, bx             ; restore DS = VGA segment
  1162 00000672 84C0                        test al, al
  1163 00000674 740B                        jz .wss_done
  1164 00000676 8805                        mov [di], al
  1165 00000678 886501                      mov [di+1], ah
  1166 0000067B 83C702                      add di, 2
  1167 0000067E 46                          inc si
  1168 0000067F EBEB                        jmp short .wss_loop
  1169                                  .wss_done:
  1170 00000681 5B                          pop bx
  1171 00000682 C3                          ret
  1172                                  
  1173                                  ; --- BIOS print: print null-terminated string at CS:SI via INT 10h ---
  1174                                  bios_print:
  1175 00000683 50                          push ax
  1176 00000684 53                          push bx
  1177                                  .bp_loop:
  1178 00000685 1E                          push ds
  1179 00000686 0E                          push cs
  1180 00000687 1F                          pop ds
  1181 00000688 8A04                        mov al, [si]
  1182 0000068A 1F                          pop ds
  1183 0000068B 84C0                        test al, al
  1184 0000068D 740A                        jz .bp_done
  1185 0000068F B40E                        mov ah, 0x0E
  1186 00000691 BB0700                      mov bx, 0x0007
  1187 00000694 CD10                        int 0x10
  1188 00000696 46                          inc si
  1189 00000697 EBEC                        jmp short .bp_loop
  1190                                  .bp_done:
