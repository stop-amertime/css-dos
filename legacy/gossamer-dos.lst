     1                                  ; gossamer-dos.asm — Gossamer BIOS (DOS variant) for CSS-DOS
     2                                  ; Loaded at F000:0000 (linear 0xF0000)
     3                                  ;
     4                                  ; Mirrors the 8088_bios reference layout:
     5                                  ;   - IVT setup via interrupt_table array (32 standard vectors + fill rest)
     6                                  ;   - Full BDA initialization matching IBM PC BIOS
     7                                  ;   - INT handlers follow reference contracts
     8                                  ;
     9                                  ; Backend is memory-mapped (no port I/O):
    10                                  ;   - VGA text buffer at B800:0000
    11                                  ;   - Disk image at D000:0000
    12                                  ;   - Keyboard input via BDA ring buffer at 0040:001E (standard PC convention)
    13                                  ;     Host writes (scancode<<8|ascii) word into the ring buffer before each tick.
    14                                  ;
    15                                  ; DOS kernel (KERNEL.SYS) is pre-loaded at 0060:0000 (linear 0x600)
    16                                  ; by the transpiler. The BIOS init code sets up the IVT and jumps to it.
    17                                  ;
    18                                  ; CONSTRAINTS (CSS transpiler limitations):
    19                                  ; - No 0x0F-prefixed opcodes (near Jcc)
    20                                  ; - Must compile with NASM: [bits 16] [org 0]
    21                                  
    22                                  [bits 16]
    23                                  [org 0]
    24                                  
    25                                  ; ============================================================
    26                                  ; Constants
    27                                  ; ============================================================
    28                                  DISK_SEG    equ 0xD000          ; Disk image loaded here (linear 0xD0000)
    29                                  BDA_SEG     equ 0x0040          ; BIOS Data Area segment
    30                                  BIOS_SEG    equ 0xF000          ; BIOS code segment
    31                                  VGA_SEG     equ 0xB800          ; VGA text mode segment
    32                                  KERNEL_SEG  equ 0x0060          ; DOS kernel load segment
    33                                  SECTOR_SIZE equ 512
    34                                  HALT_ADDR   equ 0x0504          ; Halt flag address (seg 0)
    35                                  
    36                                  ; Disk geometry for a 1.44MB floppy
    37                                  DISK_SPT    equ 18              ; sectors per track
    38                                  DISK_HEADS  equ 2               ; heads
    39                                  DISK_CYLS   equ 80              ; cylinders
    40                                  
    41                                  ; BDA offsets (matching reference 8088_bios exactly)
    42                                  equip_serial        equ 0x00    ; word[4] - serial port addresses
    43                                  equip_parallel      equ 0x08   ; word[3] - parallel port addresses
    44                                  equipment_list      equ 0x10    ; word - equipment list
    45                                  memory_size         equ 0x13    ; word - memory size in KiB
    46                                  kbd_flags_1         equ 0x17    ; byte - keyboard shift flags 1
    47                                  kbd_flags_2         equ 0x18    ; byte - keyboard shift flags 2
    48                                  kbd_alt_keypad      equ 0x19    ; byte - Alt+Numpad work area
    49                                  kbd_buffer_head     equ 0x1A    ; word - keyboard buffer head offset
    50                                  kbd_buffer_tail     equ 0x1C    ; word - keyboard buffer tail offset
    51                                  kbd_buffer          equ 0x1E    ; byte[32] - keyboard buffer
    52                                  fdc_calib_state     equ 0x3E    ; byte - floppy recalibration status
    53                                  fdc_motor_state     equ 0x3F    ; byte - floppy motor status
    54                                  fdc_motor_tout      equ 0x40    ; byte - floppy motor off timeout
    55                                  fdc_last_error      equ 0x41    ; byte - last diskette op status
    56                                  video_mode          equ 0x49    ; byte - active video mode
    57                                  video_columns       equ 0x4A    ; word - text columns
    58                                  video_page_size     equ 0x4C    ; word - video page size in bytes
    59                                  video_page_offt     equ 0x4E    ; word - active video page offset
    60                                  video_cur_pos       equ 0x50    ; byte[16] - cursor pos per page
    61                                  video_cur_shape     equ 0x60    ; word - cursor shape
    62                                  video_page          equ 0x62    ; byte - active video page
    63                                  video_port          equ 0x63    ; word - CRT controller port
    64                                  ticks_lo            equ 0x6C    ; word - timer ticks low
    65                                  ticks_hi            equ 0x6E    ; word - timer ticks high
    66                                  new_day             equ 0x70    ; byte - midnight flag
    67                                  break_flag          equ 0x71    ; byte - Ctrl-Break flag
    68                                  warm_boot           equ 0x72    ; word - warm boot flag (1234h)
    69                                  kbd_buffer_start    equ 0x80    ; word - keyboard buffer start
    70                                  kbd_buffer_end      equ 0x82    ; word - keyboard buffer end
    71                                  video_rows          equ 0x84    ; byte - text rows minus 1
    72                                  video_char_height   equ 0x85    ; word - character height (points)
    73                                  
    74                                  ; ============================================================
    75                                  ; INT 10h — Video Services
    76                                  ; ============================================================
    77                                  int10h_handler:
    78 00000000 1E                          push ds
    79 00000001 06                          push es
    80 00000002 55                          push bp
    81 00000003 80FC0E                      cmp ah, 0x0E
    82 00000006 7403                        je .teletype
    83 00000008 E98800                      jmp .dispatch_other
    84                                  
    85                                  ; --- AH=0Eh: Teletype output ---
    86                                  .teletype:
    87 0000000B 57                          push di
    88 0000000C 53                          push bx
    89 0000000D 51                          push cx
    90 0000000E 52                          push dx
    91 0000000F 50                          push ax                ; save character in AL
    92                                  
    93                                      ; Read cursor from BDA
    94 00000010 BB4000                      mov bx, BDA_SEG
    95 00000013 8EDB                        mov ds, bx
    96 00000015 8A165000                    mov dl, [video_cur_pos]     ; column
    97 00000019 8A365100                    mov dh, [video_cur_pos+1]   ; row
    98                                  
    99 0000001D 58                          pop ax                 ; AX restored (AL = character)
   100 0000001E 50                          push ax                ; save again
   101                                  
   102 0000001F 3C0D                        cmp al, 13
   103 00000021 7444                        je .tty_cr
   104 00000023 3C0A                        cmp al, 10
   105 00000025 7444                        je .tty_lf
   106 00000027 3C08                        cmp al, 8
   107 00000029 744E                        je .tty_bs
   108 0000002B 3C07                        cmp al, 7
   109 0000002D 745B                        je .tty_done
   110                                  
   111                                      ; Compute VGA offset = (row*80+col)*2
   112 0000002F 50                          push ax                ; save char
   113 00000030 52                          push dx                ; save cursor
   114 00000031 88F0                        mov al, dh
   115 00000033 B350                        mov bl, 80
   116 00000035 F6E3                        mul bl                 ; AX = row*80
   117 00000037 30FF                        xor bh, bh
   118 00000039 88D3                        mov bl, dl
   119 0000003B 01D8                        add ax, bx             ; AX = row*80+col
   120 0000003D D1E0                        shl ax, 1              ; AX = (row*80+col)*2
   121 0000003F 89C7                        mov di, ax
   122 00000041 5A                          pop dx                 ; restore cursor
   123 00000042 58                          pop ax                 ; restore char
   124                                  
   125                                      ; Write to VGA
   126 00000043 1E                          push ds
   127 00000044 BB00B8                      mov bx, VGA_SEG
   128 00000047 8EDB                        mov ds, bx
   129 00000049 8805                        mov [di], al           ; character
   130 0000004B C6450107                    mov byte [di+1], 0x07  ; attribute
   131 0000004F 1F                          pop ds
   132                                  
   133                                      ; Advance cursor
   134 00000050 FEC2                        inc dl
   135 00000052 80FA50                      cmp dl, 80
   136 00000055 722B                        jb .tty_save
   137 00000057 30D2                        xor dl, dl
   138 00000059 FEC6                        inc dh
   139 0000005B 80FE19                      cmp dh, 25
   140 0000005E 7222                        jb .tty_save
   141 00000060 FECE                        dec dh
   142 00000062 E81B02                      call scroll_up_one
   143 00000065 EB1B                        jmp short .tty_save
   144                                  
   145                                  .tty_cr:
   146 00000067 30D2                        xor dl, dl
   147 00000069 EB17                        jmp short .tty_save
   148                                  
   149                                  .tty_lf:
   150 0000006B FEC6                        inc dh
   151 0000006D 80FE19                      cmp dh, 25
   152 00000070 7210                        jb .tty_save
   153 00000072 FECE                        dec dh
   154 00000074 E80902                      call scroll_up_one
   155 00000077 EB09                        jmp short .tty_save
   156                                  
   157                                  .tty_bs:
   158 00000079 80FA00                      cmp dl, 0
   159 0000007C 7404                        je .tty_save
   160 0000007E FECA                        dec dl
   161 00000080 EB00                        jmp short .tty_save
   162                                  
   163                                  .tty_save:
   164 00000082 88165000                    mov [video_cur_pos], dl
   165 00000086 88365100                    mov [video_cur_pos+1], dh
   166                                  
   167                                  .tty_done:
   168 0000008A 58                          pop ax
   169 0000008B 5A                          pop dx
   170 0000008C 59                          pop cx
   171 0000008D 5B                          pop bx
   172 0000008E 5F                          pop di
   173 0000008F 5D                          pop bp
   174 00000090 07                          pop es
   175 00000091 1F                          pop ds
   176 00000092 CF                          iret
   177                                  
   178                                  ; --- INT 10h dispatch for non-teletype ---
   179                                  .dispatch_other:
   180 00000093 80FC02                      cmp ah, 0x02
   181 00000096 7442                        je .set_cursor
   182 00000098 80FC03                      cmp ah, 0x03
   183 0000009B 744E                        je .get_cursor
   184 0000009D 80FC00                      cmp ah, 0x00
   185 000000A0 7472                        je .set_mode
   186 000000A2 80FC0F                      cmp ah, 0x0F
   187 000000A5 7459                        je .get_mode
   188 000000A7 80FC06                      cmp ah, 0x06
   189 000000AA 7503                        jne .not_scroll_up
   190 000000AC E9B800                      jmp .scroll_up
   191                                  .not_scroll_up:
   192 000000AF 80FC07                      cmp ah, 0x07
   193 000000B2 7503                        jne .not_scroll_down
   194 000000B4 E9E200                      jmp .scroll_down
   195                                  .not_scroll_down:
   196 000000B7 80FC08                      cmp ah, 0x08
   197 000000BA 7503                        jne .not_read_char
   198 000000BC E9FB00                      jmp .read_char
   199                                  .not_read_char:
   200 000000BF 80FC09                      cmp ah, 0x09
   201 000000C2 7503                        jne .not_write_char
   202 000000C4 E92501                      jmp .write_char_attr
   203                                  .not_write_char:
   204 000000C7 80FC0A                      cmp ah, 0x0A
   205 000000CA 7503                        jne .not_write_char_only
   206 000000CC E95A01                      jmp .write_char_only
   207                                  .not_write_char_only:
   208 000000CF 80FC1A                      cmp ah, 0x1A
   209 000000D2 0F848B01                    je .get_display_combo
   210 000000D6 5D                          pop bp
   211 000000D7 07                          pop es
   212 000000D8 1F                          pop ds
   213 000000D9 CF                          iret
   214                                  
   215                                  .set_cursor:
   216 000000DA BB4000                      mov bx, BDA_SEG
   217 000000DD 8EDB                        mov ds, bx
   218 000000DF 88165000                    mov [video_cur_pos], dl
   219 000000E3 88365100                    mov [video_cur_pos+1], dh
   220 000000E7 5D                          pop bp
   221 000000E8 07                          pop es
   222 000000E9 1F                          pop ds
   223 000000EA CF                          iret
   224                                  
   225                                  .get_cursor:
   226 000000EB BB4000                      mov bx, BDA_SEG
   227 000000EE 8EDB                        mov ds, bx
   228 000000F0 8A165000                    mov dl, [video_cur_pos]
   229 000000F4 8A365100                    mov dh, [video_cur_pos+1]
   230 000000F8 8B0E6000                    mov cx, [video_cur_shape]
   231 000000FC 5D                          pop bp
   232 000000FD 07                          pop es
   233 000000FE 1F                          pop ds
   234 000000FF CF                          iret
   235                                  
   236                                  .get_mode:
   237 00000100 BB4000                      mov bx, BDA_SEG
   238 00000103 8EDB                        mov ds, bx
   239 00000105 A04900                      mov al, [video_mode]
   240 00000108 8A264A00                    mov ah, [video_columns]
   241 0000010C 8A3E6200                    mov bh, [video_page]
   242 00000110 5D                          pop bp
   243 00000111 07                          pop es
   244 00000112 1F                          pop ds
   245 00000113 CF                          iret
   246                                  
   247                                  .set_mode:
   248 00000114 57                          push di
   249 00000115 51                          push cx
   250 00000116 50                          push ax
   251                                      ; Store requested mode in BDA and reset cursor
   252 00000117 B94000                      mov cx, BDA_SEG
   253 0000011A 8ED9                        mov ds, cx
   254 0000011C C606500000                  mov byte [video_cur_pos], 0
   255 00000121 C606510000                  mov byte [video_cur_pos+1], 0
   256                                      ; Only store modes we actually support; map anything else to 0x03.
   257                                      ; Programs like rogue request modes (e.g. 0x11 EGA/VGA mono) that we
   258                                      ; can't emulate — fall back to text so BDA stays consistent.
   259 00000126 3C13                        cmp al, 0x13
   260 00000128 7402                        je .set_mode_store
   261 0000012A B003                        mov al, 0x03                ; unsupported mode → fall back to text
   262                                  .set_mode_store:
   263 0000012C A24900                      mov [video_mode], al
   264                                      ; Branch on mode: AL=0x13 → Mode 13h graphics, else text
   265 0000012F 3C13                        cmp al, 0x13
   266 00000131 7417                        je .set_mode_13h
   267                                      ; --- Text mode: clear 80x25 text buffer at 0xB8000 ---
   268 00000133 B800B8                      mov ax, VGA_SEG
   269 00000136 8ED8                        mov ds, ax
   270 00000138 31FF                        xor di, di
   271 0000013A B9D007                      mov cx, 2000
   272 0000013D B82007                      mov ax, 0x0720
   273                                  .clr_loop:
   274 00000140 8905                        mov [di], ax
   275 00000142 83C702                      add di, 2
   276 00000145 49                          dec cx
   277 00000146 75F8                        jnz .clr_loop
   278 00000148 EB14                        jmp short .set_mode_done
   279                                  .set_mode_13h:
   280                                      ; --- Mode 13h: clear 320x200 framebuffer at 0xA0000 ---
   281 0000014A B800A0                      mov ax, 0xA000
   282 0000014D 8ED8                        mov ds, ax
   283 0000014F 31FF                        xor di, di
   284 00000151 B9007D                      mov cx, 32000
   285 00000154 31C0                        xor ax, ax
   286                                  .clr13_loop:
   287 00000156 8905                        mov [di], ax
   288 00000158 83C702                      add di, 2
   289 0000015B 49                          dec cx
   290 0000015C 75F8                        jnz .clr13_loop
   291                                  .set_mode_done:
   292 0000015E 58                          pop ax
   293 0000015F B030                        mov al, 0x30           ; return prior mode info (AL bit 7 = don't clear flag, we ignore)
   294 00000161 59                          pop cx
   295 00000162 5F                          pop di
   296 00000163 5D                          pop bp
   297 00000164 07                          pop es
   298 00000165 1F                          pop ds
   299 00000166 CF                          iret
   300                                  
   301                                  .scroll_up:
   302 00000167 3C00                        cmp al, 0
   303 00000169 751D                        jne .su_lines
   304                                      ; AL=0: Clear window
   305 0000016B 57                          push di
   306 0000016C 51                          push cx
   307 0000016D B900B8                      mov cx, VGA_SEG
   308 00000170 8ED9                        mov ds, cx
   309 00000172 31FF                        xor di, di
   310 00000174 B9D007                      mov cx, 2000
   311 00000177 B82007                      mov ax, 0x0720
   312                                  .su_clr:
   313 0000017A 8905                        mov [di], ax
   314 0000017C 83C702                      add di, 2
   315 0000017F 49                          dec cx
   316 00000180 75F8                        jnz .su_clr
   317 00000182 59                          pop cx
   318 00000183 5F                          pop di
   319 00000184 5D                          pop bp
   320 00000185 07                          pop es
   321 00000186 1F                          pop ds
   322 00000187 CF                          iret
   323                                  .su_lines:
   324 00000188 51                          push cx
   325 00000189 88C1                        mov cl, al
   326 0000018B 30ED                        xor ch, ch
   327                                  .su_loop:
   328 0000018D E8F000                      call scroll_up_one
   329 00000190 FEC9                        dec cl
   330 00000192 75F9                        jnz .su_loop
   331 00000194 59                          pop cx
   332 00000195 5D                          pop bp
   333 00000196 07                          pop es
   334 00000197 1F                          pop ds
   335 00000198 CF                          iret
   336                                  
   337                                  .scroll_down:
   338 00000199 3C00                        cmp al, 0
   339 0000019B 7519                        jne .sd_ret
   340 0000019D 57                          push di
   341 0000019E 51                          push cx
   342 0000019F B900B8                      mov cx, VGA_SEG
   343 000001A2 8ED9                        mov ds, cx
   344 000001A4 31FF                        xor di, di
   345 000001A6 B9D007                      mov cx, 2000
   346 000001A9 B82007                      mov ax, 0x0720
   347                                  .sd_clr:
   348 000001AC 8905                        mov [di], ax
   349 000001AE 83C702                      add di, 2
   350 000001B1 49                          dec cx
   351 000001B2 75F8                        jnz .sd_clr
   352 000001B4 59                          pop cx
   353 000001B5 5F                          pop di
   354                                  .sd_ret:
   355 000001B6 5D                          pop bp
   356 000001B7 07                          pop es
   357 000001B8 1F                          pop ds
   358 000001B9 CF                          iret
   359                                  
   360                                  .read_char:
   361                                      ; AH=08h: Read char+attr at cursor
   362 000001BA 53                          push bx
   363 000001BB 57                          push di
   364 000001BC BB4000                      mov bx, BDA_SEG
   365 000001BF 8EDB                        mov ds, bx
   366 000001C1 A05000                      mov al, [video_cur_pos]     ; col
   367 000001C4 8A265100                    mov ah, [video_cur_pos+1]   ; row
   368 000001C8 52                          push dx
   369 000001C9 30F6                        xor dh, dh
   370 000001CB 88E2                        mov dl, ah
   371 000001CD B450                        mov ah, 80
   372 000001CF 86C2                        xchg al, dl
   373 000001D1 F6E4                        mul ah
   374 000001D3 30F6                        xor dh, dh
   375 000001D5 01D0                        add ax, dx
   376 000001D7 D1E0                        shl ax, 1
   377 000001D9 89C7                        mov di, ax
   378 000001DB 5A                          pop dx
   379 000001DC BB00B8                      mov bx, VGA_SEG
   380 000001DF 8EDB                        mov ds, bx
   381 000001E1 8A05                        mov al, [di]           ; character
   382 000001E3 8A6501                      mov ah, [di+1]         ; attribute
   383 000001E6 5F                          pop di
   384 000001E7 5B                          pop bx
   385 000001E8 5D                          pop bp
   386 000001E9 07                          pop es
   387 000001EA 1F                          pop ds
   388 000001EB CF                          iret
   389                                  
   390                                  .write_char_attr:
   391                                      ; AH=09h: Write char+attr at cursor, CX times
   392                                      ; AL=char, BL=attr, CX=count
   393 000001EC 57                          push di
   394 000001ED 52                          push dx
   395 000001EE 51                          push cx
   396 000001EF 53                          push bx
   397 000001F0 BB4000                      mov bx, BDA_SEG
   398 000001F3 8EDB                        mov ds, bx
   399 000001F5 8A165000                    mov dl, [video_cur_pos]
   400 000001F9 8A365100                    mov dh, [video_cur_pos+1]
   401 000001FD 50                          push ax
   402 000001FE 88F0                        mov al, dh
   403 00000200 B350                        mov bl, 80
   404 00000202 F6E3                        mul bl
   405 00000204 30FF                        xor bh, bh
   406 00000206 88D3                        mov bl, dl
   407 00000208 01D8                        add ax, bx
   408 0000020A D1E0                        shl ax, 1
   409 0000020C 89C7                        mov di, ax
   410 0000020E 58                          pop ax
   411 0000020F BB00B8                      mov bx, VGA_SEG
   412 00000212 8EDB                        mov ds, bx
   413 00000214 5B                          pop bx                 ; restore original BX (BL=attr)
   414 00000215 53                          push bx
   415                                  .wca_loop:
   416 00000216 8805                        mov [di], al
   417 00000218 885D01                      mov [di+1], bl
   418 0000021B 83C702                      add di, 2
   419 0000021E 49                          dec cx
   420 0000021F 75F5                        jnz .wca_loop
   421 00000221 5B                          pop bx
   422 00000222 59                          pop cx
   423 00000223 5A                          pop dx
   424 00000224 5F                          pop di
   425 00000225 5D                          pop bp
   426 00000226 07                          pop es
   427 00000227 1F                          pop ds
   428 00000228 CF                          iret
   429                                  
   430                                  .write_char_only:
   431                                      ; AH=0Ah: Write char at cursor, CX times (keep existing attr)
   432                                      ; AL=char, CX=count
   433 00000229 57                          push di
   434 0000022A 52                          push dx
   435 0000022B 51                          push cx
   436 0000022C 53                          push bx
   437 0000022D BB4000                      mov bx, BDA_SEG
   438 00000230 8EDB                        mov ds, bx
   439 00000232 8A165000                    mov dl, [video_cur_pos]
   440 00000236 8A365100                    mov dh, [video_cur_pos+1]
   441 0000023A 50                          push ax
   442 0000023B 88F0                        mov al, dh
   443 0000023D B350                        mov bl, 80
   444 0000023F F6E3                        mul bl
   445 00000241 30FF                        xor bh, bh
   446 00000243 88D3                        mov bl, dl
   447 00000245 01D8                        add ax, bx
   448 00000247 D1E0                        shl ax, 1
   449 00000249 89C7                        mov di, ax
   450 0000024B 58                          pop ax
   451 0000024C BB00B8                      mov bx, VGA_SEG
   452 0000024F 8EDB                        mov ds, bx
   453                                  .wco_loop:
   454 00000251 8805                        mov [di], al           ; write char only, keep attribute
   455 00000253 83C702                      add di, 2
   456 00000256 49                          dec cx
   457 00000257 75F8                        jnz .wco_loop
   458 00000259 5B                          pop bx
   459 0000025A 59                          pop cx
   460 0000025B 5A                          pop dx
   461 0000025C 5F                          pop di
   462 0000025D 5D                          pop bp
   463 0000025E 07                          pop es
   464 0000025F 1F                          pop ds
   465 00000260 CF                          iret
   466                                  
   467                                  .get_display_combo:
   468                                      ; AH=1Ah: Get/Set Display Combination Code
   469                                      ; BL=00h → Get: return active display in BL, inactive in BH
   470                                      ; Programs use this to detect VGA. We return based on current video_mode:
   471                                      ;   text mode → BL=08h (VGA color), BH=00h (no inactive adapter)
   472                                      ;   Mode 13h  → BL=08h (VGA color), BH=00h
   473                                      ; AL=1Ah on return confirms this sub-function is supported.
   474 00000261 80FB00                      cmp bl, 0
   475 00000264 7514                        jne .dcc_set
   476                                      ; BL=00h: Get DCC
   477 00000266 53                          push bx
   478 00000267 BB4000                      mov bx, BDA_SEG
   479 0000026A 8EDB                        mov ds, bx
   480 0000026C A04900                      mov al, [video_mode]
   481 0000026F 5B                          pop bx
   482                                      ; Always report VGA color (0x08) regardless of mode
   483 00000270 B308                        mov bl, 0x08            ; active display: VGA color
   484 00000272 B700                        mov bh, 0x00            ; inactive: none
   485 00000274 5D                          pop bp
   486 00000275 07                          pop es
   487 00000276 1F                          pop ds
   488 00000277 B01A                        mov al, 0x1A            ; confirm supported
   489 00000279 CF                          iret
   490                                  .dcc_set:
   491                                      ; BL != 00h: Set DCC — we accept but ignore (can't change the CSS adapter)
   492 0000027A 5D                          pop bp
   493 0000027B 07                          pop es
   494 0000027C 1F                          pop ds
   495 0000027D B01A                        mov al, 0x1A
   496 0000027F CF                          iret
   497                                  
   498                                  ; ============================================================
   499                                  ; scroll_up_one — scroll VGA text up by one line
   500                                  ; ============================================================
   501                                  scroll_up_one:
   502 00000280 1E                          push ds
   503 00000281 56                          push si
   504 00000282 57                          push di
   505 00000283 51                          push cx
   506 00000284 50                          push ax
   507 00000285 B800B8                      mov ax, VGA_SEG
   508 00000288 8ED8                        mov ds, ax
   509 0000028A BEA000                      mov si, 160            ; source = row 1
   510 0000028D 31FF                        xor di, di             ; dest = row 0
   511 0000028F B98007                      mov cx, 1920           ; 24 rows * 80 cols
   512                                  .scopy:
   513 00000292 8B04                        mov ax, [si]
   514 00000294 8905                        mov [di], ax
   515 00000296 83C602                      add si, 2
   516 00000299 83C702                      add di, 2
   517 0000029C 49                          dec cx
   518 0000029D 75F3                        jnz .scopy
   519 0000029F B95000                      mov cx, 80
   520 000002A2 B82007                      mov ax, 0x0720
   521                                  .sclear:
   522 000002A5 8905                        mov [di], ax
   523 000002A7 83C702                      add di, 2
   524 000002AA 49                          dec cx
   525 000002AB 75F8                        jnz .sclear
   526 000002AD 58                          pop ax
   527 000002AE 59                          pop cx
   528 000002AF 5F                          pop di
   529 000002B0 5E                          pop si
   530 000002B1 1F                          pop ds
   531 000002B2 C3                          ret
   532                                  
   533                                  ; ============================================================
   534                                  ; INT 11h — Equipment List (read from BDA, like reference BIOS)
   535                                  ; ============================================================
   536                                  int11h_handler:
   537 000002B3 FB                          sti
   538 000002B4 1E                          push ds
   539 000002B5 B84000                      mov ax, BDA_SEG
   540 000002B8 8ED8                        mov ds, ax
   541 000002BA A11000                      mov ax, [equipment_list]
   542 000002BD 1F                          pop ds
   543 000002BE CF                          iret
   544                                  
   545                                  ; ============================================================
   546                                  ; INT 12h — Memory Size (read from BDA, like reference BIOS)
   547                                  ; ============================================================
   548                                  int12h_handler:
   549 000002BF FB                          sti
   550 000002C0 1E                          push ds
   551 000002C1 B84000                      mov ax, BDA_SEG
   552 000002C4 8ED8                        mov ds, ax
   553 000002C6 A11300                      mov ax, [memory_size]
   554 000002C9 1F                          pop ds
   555 000002CA CF                          iret
   556                                  
   557                                  ; ============================================================
   558                                  ; INT 13h — Disk Services (memory-resident disk image)
   559                                  ; ============================================================
   560                                  int13h_handler:
   561 000002CB 80FC00                      cmp ah, 0x00
   562 000002CE 7413                        je .disk_reset
   563 000002D0 80FC02                      cmp ah, 0x02
   564 000002D3 742E                        je .disk_read
   565 000002D5 80FC08                      cmp ah, 0x08
   566 000002D8 740D                        je .disk_params
   567 000002DA 80FC15                      cmp ah, 0x15
   568 000002DD 7420                        je .disk_type
   569                                      ; Unknown function — return error
   570 000002DF B401                        mov ah, 0x01           ; invalid function
   571 000002E1 F9                          stc
   572 000002E2 CF                          iret
   573                                  
   574                                  .disk_reset:
   575 000002E3 30E4                        xor ah, ah
   576 000002E5 F8                          clc
   577 000002E6 CF                          iret
   578                                  
   579                                  .disk_params:
   580                                      ; Return drive parameters for 1.44MB floppy
   581 000002E7 B400                        mov ah, 0
   582 000002E9 B304                        mov bl, 0x04           ; drive type: 1.44MB
   583 000002EB B54F                        mov ch, DISK_CYLS - 1  ; max cylinder (79)
   584 000002ED B112                        mov cl, DISK_SPT       ; max sector (18)
   585 000002EF B601                        mov dh, DISK_HEADS - 1 ; max head (1)
   586 000002F1 B201                        mov dl, 1              ; 1 floppy drive
   587                                      ; ES:DI = disk parameter table
   588 000002F3 53                          push bx
   589 000002F4 BB00F0                      mov bx, BIOS_SEG
   590 000002F7 8EC3                        mov es, bx
   591 000002F9 BF[EC06]                    mov di, disk_param_table
   592 000002FC 5B                          pop bx
   593 000002FD F8                          clc
   594 000002FE CF                          iret
   595                                  
   596                                  .disk_type:
   597                                      ; AH=15h: Get disk type — floppy without change detection
   598 000002FF B401                        mov ah, 0x01
   599 00000301 F8                          clc
   600 00000302 CF                          iret
   601                                  
   602                                  .disk_read:
   603                                      ; AH=02h: Read sectors
   604                                      ; AL=count, CH=cylinder, CL=sector(1-based), DH=head, DL=drive, ES:BX=dest
   605 00000303 55                          push bp
   606 00000304 89E5                        mov bp, sp
   607 00000306 1E                          push ds
   608 00000307 56                          push si
   609 00000308 57                          push di
   610 00000309 50                          push ax
   611 0000030A 52                          push dx
   612 0000030B 51                          push cx
   613                                  
   614                                      ; Reload from stack since we need all values
   615 0000030C 59                          pop cx
   616 0000030D 5A                          pop dx
   617 0000030E 52                          push dx
   618 0000030F 51                          push cx
   619                                  
   620                                      ; Compute LBA = (CH * 2 + DH) * 18 + (CL - 1)
   621 00000310 88E8                        mov al, ch
   622 00000312 30E4                        xor ah, ah
   623 00000314 D1E0                        shl ax, 1              ; AX = cyl * 2
   624 00000316 89C6                        mov si, ax
   625 00000318 30E4                        xor ah, ah
   626 0000031A 88F0                        mov al, dh
   627 0000031C 01F0                        add ax, si             ; AX = cyl*2 + head
   628 0000031E BE1200                      mov si, DISK_SPT
   629 00000321 52                          push dx
   630 00000322 F7E6                        mul si                 ; AX = (cyl*2+head) * 18
   631 00000324 5A                          pop dx
   632 00000325 89C6                        mov si, ax
   633 00000327 30ED                        xor ch, ch
   634 00000329 FEC9                        dec cl                 ; sector is 1-based
   635 0000032B 01CE                        add si, cx             ; SI = LBA
   636                                  
   637                                      ; Source segment = DISK_SEG + LBA * 32
   638 0000032D 89F0                        mov ax, si
   639 0000032F B105                        mov cl, 5
   640 00000331 D3E0                        shl ax, cl
   641 00000333 0500D0                      add ax, DISK_SEG
   642 00000336 8ED8                        mov ds, ax
   643 00000338 31F6                        xor si, si
   644                                  
   645                                      ; Destination = ES:BX
   646 0000033A 89DF                        mov di, bx
   647                                  
   648                                      ; Count
   649 0000033C 59                          pop cx
   650 0000033D 5A                          pop dx
   651 0000033E 58                          pop ax
   652 0000033F 30E4                        xor ah, ah
   653 00000341 89C1                        mov cx, ax
   654 00000343 51                          push cx
   655                                  
   656                                      ; Copy CX sectors * 512 bytes
   657                                  .read_sector_loop:
   658 00000344 51                          push cx
   659 00000345 B90001                      mov cx, 256
   660                                  .read_word_loop:
   661 00000348 8B04                        mov ax, [si]
   662 0000034A 1E                          push ds
   663 0000034B 53                          push bx
   664 0000034C 8CC3                        mov bx, es
   665 0000034E 8EDB                        mov ds, bx
   666 00000350 8905                        mov [di], ax
   667 00000352 5B                          pop bx
   668 00000353 1F                          pop ds
   669 00000354 83C602                      add si, 2
   670 00000357 83C702                      add di, 2
   671 0000035A 49                          dec cx
   672 0000035B 75EB                        jnz .read_word_loop
   673 0000035D 59                          pop cx
   674 0000035E 49                          dec cx
   675 0000035F 75E3                        jnz .read_sector_loop
   676                                  
   677                                      ; Success
   678 00000361 58                          pop ax                 ; AL = sectors read
   679 00000362 30E4                        xor ah, ah
   680 00000364 F8                          clc
   681 00000365 5F                          pop di
   682 00000366 5E                          pop si
   683 00000367 1F                          pop ds
   684 00000368 5D                          pop bp
   685 00000369 CF                          iret
   686                                  
   687                                  ; ============================================================
   688                                  ; INT 16h — Keyboard Services (matches reference BIOS contracts)
   689                                  ; ============================================================
   690                                  int16h_handler:
   691 0000036A FB                          sti
   692 0000036B 53                          push bx
   693 0000036C 1E                          push ds
   694 0000036D BB4000                      mov bx, BDA_SEG
   695 00000370 8EDB                        mov ds, bx
   696 00000372 80FC00                      cmp ah, 0x00
   697 00000375 741C                        je .read_key
   698 00000377 80FC01                      cmp ah, 0x01
   699 0000037A 7437                        je .check_key
   700 0000037C 80FC02                      cmp ah, 0x02
   701 0000037F 7454                        je .shift_flags
   702 00000381 80FC10                      cmp ah, 0x10
   703 00000384 740D                        je .read_key           ; enhanced = same for us
   704 00000386 80FC11                      cmp ah, 0x11
   705 00000389 7428                        je .check_key          ; enhanced = same for us
   706 0000038B 80FC12                      cmp ah, 0x12
   707 0000038E 744B                        je .ext_shift_flags
   708                                      ; Unknown function
   709 00000390 1F                          pop ds
   710 00000391 5B                          pop bx
   711 00000392 CF                          iret
   712                                  
   713                                  .read_key:
   714                                      ; AH=00h/10h: Block until a key is in the BDA ring buffer, then pop it.
   715                                      ; DS is already BDA_SEG from handler entry.
   716                                  .key_wait:
   717 00000393 8B1E1A00                    mov bx, [kbd_buffer_head]
   718 00000397 3B1E1C00                    cmp bx, [kbd_buffer_tail]
   719 0000039B 74F6                        je .key_wait                ; buffer empty — spin
   720 0000039D 8B07                        mov ax, [bx]                ; read (scancode<<8 | ascii) word
   721 0000039F 83C302                      add bx, 2
   722 000003A2 3B1E8200                    cmp bx, [kbd_buffer_end]    ; wrap around ring buffer
   723 000003A6 7204                        jb .rk_nowrap
   724 000003A8 8B1E8000                    mov bx, [kbd_buffer_start]
   725                                  .rk_nowrap:
   726 000003AC 891E1A00                    mov [kbd_buffer_head], bx   ; advance head (consumes the entry)
   727 000003B0 1F                          pop ds
   728 000003B1 5B                          pop bx
   729 000003B2 CF                          iret                        ; AX = key word
   730                                  
   731                                  .check_key:
   732                                      ; AH=01h/11h: Non-destructive peek. Set ZF if buffer empty, clear if key waiting.
   733                                      ; DS is already BDA_SEG from handler entry.
   734 000003B3 8B1E1A00                    mov bx, [kbd_buffer_head]
   735 000003B7 3B1E1C00                    cmp bx, [kbd_buffer_tail]
   736 000003BB 740D                        je .ck_empty
   737 000003BD 8B07                        mov ax, [bx]                ; peek at next key (don't consume)
   738 000003BF 1F                          pop ds
   739 000003C0 5B                          pop bx
   740 000003C1 55                          push bp
   741 000003C2 89E5                        mov bp, sp
   742 000003C4 836606BF                    and word [bp+6], 0xFFBF     ; clear ZF — key available
   743 000003C8 5D                          pop bp
   744 000003C9 CF                          iret
   745                                  .ck_empty:
   746 000003CA 1F                          pop ds
   747 000003CB 5B                          pop bx
   748 000003CC 55                          push bp
   749 000003CD 89E5                        mov bp, sp
   750 000003CF 834E0640                    or word [bp+6], 0x0040      ; set ZF — no key
   751 000003D3 5D                          pop bp
   752 000003D4 CF                          iret
   753                                  
   754                                  .shift_flags:
   755                                      ; AH=02h: Return shift flags from BDA
   756 000003D5 A01700                      mov al, [kbd_flags_1]
   757 000003D8 1F                          pop ds
   758 000003D9 5B                          pop bx
   759 000003DA CF                          iret
   760                                  
   761                                  .ext_shift_flags:
   762                                      ; AH=12h: Return extended shift flags
   763 000003DB A01700                      mov al, [kbd_flags_1]
   764 000003DE 8A261800                    mov ah, [kbd_flags_2]
   765 000003E2 1F                          pop ds
   766 000003E3 5B                          pop bx
   767 000003E4 CF                          iret
   768                                  
   769                                  ; ============================================================
   770                                  ; INT 1Ah — Timer Services (matches reference BIOS contract)
   771                                  ; ============================================================
   772                                  int1ah_handler:
   773 000003E5 FB                          sti
   774 000003E6 53                          push bx
   775 000003E7 1E                          push ds
   776 000003E8 BB4000                      mov bx, BDA_SEG
   777 000003EB 8EDB                        mov ds, bx
   778 000003ED 80FC00                      cmp ah, 0x00
   779 000003F0 7408                        je .timer_read
   780 000003F2 80FC01                      cmp ah, 0x01
   781 000003F5 741F                        je .timer_set
   782                                      ; Unknown function
   783 000003F7 1F                          pop ds
   784 000003F8 5B                          pop bx
   785 000003F9 CF                          iret
   786                                  
   787                                  .timer_read:
   788                                      ; AH=00h: Read tick count
   789                                      ; Returns: CX=high, DX=low, AL=midnight flag
   790                                      ; Reference: reads ticks, clears midnight flag via XOR
   791 000003FA 8B166C00                    mov dx, [ticks_lo]
   792 000003FE 8B0E6E00                    mov cx, [ticks_hi]
   793 00000402 A07000                      mov al, [new_day]
   794 00000405 30067000                    xor byte [new_day], al  ; clear midnight flag (reference method)
   795                                      ; Auto-increment workaround since we have no timer IRQ
   796 00000409 83066C0001                  add word [ticks_lo], 1
   797 0000040E 83166E0000                  adc word [ticks_hi], 0
   798 00000413 1F                          pop ds
   799 00000414 5B                          pop bx
   800 00000415 CF                          iret
   801                                  
   802                                  .timer_set:
   803                                      ; AH=01h: Set tick count
   804 00000416 89166C00                    mov [ticks_lo], dx
   805 0000041A 890E6E00                    mov [ticks_hi], cx
   806 0000041E C606700000                  mov byte [new_day], 0
   807 00000423 1F                          pop ds
   808 00000424 5B                          pop bx
   809 00000425 CF                          iret
   810                                  
   811                                  ; ============================================================
   812                                  ; INT 08h — Timer Tick (IRQ0)
   813                                  ; Increments BDA tick count, checks for midnight, calls INT 1Ch.
   814                                  ; We don't have a real PIT, so this won't fire automatically,
   815                                  ; but having the handler means any code that triggers INT 08h
   816                                  ; will work correctly.
   817                                  ; ============================================================
   818                                  int08h_handler:
   819 00000426 50                          push ax
   820 00000427 52                          push dx
   821 00000428 1E                          push ds
   822 00000429 B84000                      mov ax, BDA_SEG
   823 0000042C 8ED8                        mov ds, ax
   824                                      ; Increment tick counter
   825 0000042E FF066C00                    inc word [ticks_lo]
   826 00000432 7504                        jnz .no_overflow
   827 00000434 FF066E00                    inc word [ticks_hi]
   828                                  .no_overflow:
   829                                      ; Check for midnight rollover (1573042 = 0x18:0x00B2 ticks/day)
   830 00000438 833E6E0018                  cmp word [ticks_hi], 0x18
   831 0000043D 7519                        jnz .no_midnight
   832 0000043F 813E6C00B200                cmp word [ticks_lo], 0x00B2
   833 00000445 7511                        jnz .no_midnight
   834 00000447 C7066E000000                mov word [ticks_hi], 0
   835 0000044D C7066C000000                mov word [ticks_lo], 0
   836 00000453 C606700001                  mov byte [new_day], 1
   837                                  .no_midnight:
   838 00000458 CD1C                        int 0x1C               ; User timer tick hook
   839 0000045A 1F                          pop ds
   840 0000045B 5A                          pop dx
   841 0000045C 58                          pop ax
   842 0000045D CF                          iret
   843                                  
   844                                  ; ============================================================
   845                                  ; INT 15h — Miscellaneous System Services (matches reference)
   846                                  ; ============================================================
   847                                  int15h_handler:
   848 0000045E FB                          sti
   849 0000045F 80FC4F                      cmp ah, 0x4F
   850 00000462 741F                        je .kbd_intercept
   851 00000464 80FCC0                      cmp ah, 0xC0
   852 00000467 7429                        je .sys_config
   853 00000469 80FC88                      cmp ah, 0x88
   854 0000046C 7419                        je .ext_mem_size
   855                                      ; AH=90h/91h: OS hooks — return success
   856 0000046E 80FC90                      cmp ah, 0x90
   857 00000471 7411                        je .os_hook
   858 00000473 80FC91                      cmp ah, 0x91
   859 00000476 740C                        je .os_hook
   860                                      ; Unknown function — CF set, AH=86h (like reference)
   861 00000478 B486                        mov ah, 0x86
   862 0000047A 55                          push bp
   863 0000047B 89E5                        mov bp, sp
   864 0000047D 804E0601                    or byte [bp+6], 0x01   ; set CF in stacked FLAGS
   865 00000481 5D                          pop bp
   866 00000482 CF                          iret
   867                                  
   868                                  .kbd_intercept:
   869                                      ; AH=4Fh: Keyboard intercept — just IRET (pass through)
   870 00000483 CF                          iret
   871                                  
   872                                  .os_hook:
   873                                      ; AH=90h/91h: Device busy/interrupt complete — AH=0, IRET
   874 00000484 B400                        mov ah, 0x00
   875 00000486 CF                          iret
   876                                  
   877                                  .ext_mem_size:
   878                                      ; AH=88h: Extended memory size (above 1MB) — none
   879 00000487 31C0                        xor ax, ax
   880 00000489 55                          push bp
   881 0000048A 89E5                        mov bp, sp
   882 0000048C 806606FE                    and byte [bp+6], 0xFE  ; clear CF
   883 00000490 5D                          pop bp
   884 00000491 CF                          iret
   885                                  
   886                                  .sys_config:
   887                                      ; AH=C0h: Get system configuration table
   888 00000492 B400                        mov ah, 0x00
   889 00000494 BB00F0                      mov bx, BIOS_SEG
   890 00000497 8EC3                        mov es, bx
   891 00000499 BB[E206]                    mov bx, config_table
   892 0000049C 55                          push bp
   893 0000049D 89E5                        mov bp, sp
   894 0000049F 806606FE                    and byte [bp+6], 0xFE  ; clear CF
   895 000004A3 5D                          pop bp
   896 000004A4 CF                          iret
   897                                  
   898                                  ; ============================================================
   899                                  ; INT 19h — Bootstrap (halt in our system)
   900                                  ; ============================================================
   901                                  int19h_handler:
   902 000004A5 1E                          push ds
   903 000004A6 31C0                        xor ax, ax
   904 000004A8 8ED8                        mov ds, ax
   905 000004AA C606040501                  mov byte [HALT_ADDR], 1
   906 000004AF 1F                          pop ds
   907 000004B0 EBF3                        jmp int19h_handler
   908                                  
   909                                  ; ============================================================
   910                                  ; INT 20h — Program Terminate (halt)
   911                                  ; ============================================================
   912                                  int20h_handler:
   913 000004B2 1E                          push ds
   914 000004B3 31C0                        xor ax, ax
   915 000004B5 8ED8                        mov ds, ax
   916 000004B7 C606040501                  mov byte [HALT_ADDR], 1
   917 000004BC 1F                          pop ds
   918 000004BD EBF3                        jmp int20h_handler
   919                                  
   920                                  ; ============================================================
   921                                  ; INT 01h — Single-step trap handler
   922                                  ; Clears TF from stacked FLAGS so execution resumes normally.
   923                                  ; ============================================================
   924                                  int01h_handler:
   925 000004BF 55                          push bp
   926 000004C0 89E5                        mov bp, sp
   927 000004C2 816606FFFE                  and word [bp+6], 0xFEFF    ; clear TF (bit 8) in stacked FLAGS
   928 000004C7 5D                          pop bp
   929 000004C8 CF                          iret
   930                                  
   931                                  ; ============================================================
   932                                  ; int_dummy — Dummy interrupt handler (IRET only)
   933                                  ; Matches reference BIOS int_dummy at FF53h.
   934                                  ; ============================================================
   935                                  int_dummy:
   936 000004C9 CF                          iret
   937                                  
   938                                  ; ============================================================
   939                                  ; default_handler — For unimplemented INTs
   940                                  ; Returns with CF set to signal "not supported".
   941                                  ; ============================================================
   942                                  default_handler:
   943 000004CA 55                          push bp
   944 000004CB 89E5                        mov bp, sp
   945 000004CD 834E0601                    or word [bp+6], 0x0001     ; set CF in stacked FLAGS
   946 000004D1 5D                          pop bp
   947 000004D2 CF                          iret
   948                                  
   949                                  ; ============================================================
   950                                  ; Interrupt vector table — offsets only (segment always F000h)
   951                                  ; Matches reference 8088_bios interrupt_table layout exactly.
   952                                  ; 32 entries: INT 00h through INT 1Fh.
   953                                  ; ============================================================
   954                                  interrupt_table:
   955 000004D3 [C904]                      dw int_dummy            ; INT 00 - Divide by zero
   956 000004D5 [BF04]                      dw int01h_handler       ; INT 01 - Single step (clears TF)
   957 000004D7 [C904]                      dw int_dummy            ; INT 02 - NMI (no-op for us)
   958 000004D9 [C904]                      dw int_dummy            ; INT 03 - Breakpoint
   959 000004DB [C904]                      dw int_dummy            ; INT 04 - Overflow (INTO)
   960 000004DD [C904]                      dw int_dummy            ; INT 05 - Print Screen (stub)
   961 000004DF [C904]                      dw int_dummy            ; INT 06 - Invalid opcode
   962 000004E1 [C904]                      dw int_dummy            ; INT 07 - Coprocessor N/A
   963 000004E3 [2604]                      dw int08h_handler       ; INT 08 - IRQ0 Timer
   964 000004E5 [C904]                      dw int_dummy            ; INT 09 - IRQ1 Keyboard (no hw kbd)
   965 000004E7 [C904]                      dw int_dummy            ; INT 0A - IRQ2
   966 000004E9 [C904]                      dw int_dummy            ; INT 0B - IRQ3
   967 000004EB [C904]                      dw int_dummy            ; INT 0C - IRQ4
   968 000004ED [C904]                      dw int_dummy            ; INT 0D - IRQ5
   969 000004EF [C904]                      dw int_dummy            ; INT 0E - IRQ6 Floppy
   970 000004F1 [C904]                      dw int_dummy            ; INT 0F - IRQ7
   971 000004F3 [0000]                      dw int10h_handler       ; INT 10 - Video Services
   972 000004F5 [B302]                      dw int11h_handler       ; INT 11 - Equipment List
   973 000004F7 [BF02]                      dw int12h_handler       ; INT 12 - Memory Size
   974 000004F9 [CB02]                      dw int13h_handler       ; INT 13 - Disk Services
   975 000004FB [CA04]                      dw default_handler      ; INT 14 - Serial (stub)
   976 000004FD [5E04]                      dw int15h_handler       ; INT 15 - Misc System Services
   977 000004FF [6A03]                      dw int16h_handler       ; INT 16 - Keyboard Services
   978 00000501 [CA04]                      dw default_handler      ; INT 17 - Printer (stub)
   979 00000503 [C904]                      dw int_dummy            ; INT 18 - ROM BASIC (stub)
   980 00000505 [A504]                      dw int19h_handler       ; INT 19 - Bootstrap
   981 00000507 [E503]                      dw int1ah_handler       ; INT 1A - Timer Services
   982 00000509 [C904]                      dw int_dummy            ; INT 1B - Keyboard Break
   983 0000050B [C904]                      dw int_dummy            ; INT 1C - User Timer Tick (IRET hook)
   984 0000050D [C904]                      dw int_dummy            ; INT 1D - Video Parameters (stub)
   985 0000050F [EC06]                      dw disk_param_table     ; INT 1E - Floppy Parameters (data ptr)
   986 00000511 [C904]                      dw int_dummy            ; INT 1F - Font (stub)
   987                                  
   988                                  ; ============================================================
   989                                  ; BIOS Init — POST entry point
   990                                  ; Sets up IVT from interrupt_table, initializes BDA, boots DOS.
   991                                  ; ============================================================
   992                                  bios_init:
   993 00000513 FA                          cli
   994 00000514 FC                          cld
   995                                  
   996                                      ; Set up stack at 0030:0100 (reference uses upper IVT area)
   997                                      ; This is 0x0400 linear, well below kernel at 0x600.
   998 00000515 B83000                      mov ax, 0x0030
   999 00000518 8ED0                        mov ss, ax
  1000 0000051A BC0001                      mov sp, 0x0100
  1001                                  
  1002                                      ; --- Initialize interrupt table ---
  1003                                      ; Copy 32 vectors from interrupt_table (like reference BIOS).
  1004                                      ; Reference uses movsw+stosw with DS=CS, ES=0. We can't use
  1005                                      ; string ops easily, so we use a manual loop.
  1006                                      ; First, set DS=0 for IVT writes.
  1007 0000051D 31C0                        xor ax, ax
  1008 0000051F 8ED8                        mov ds, ax
  1009                                  
  1010                                      ; Fill ALL 256 IVT entries with int_dummy:F000 first
  1011                                      ; (like reference fills remaining with int_dummy after the table)
  1012 00000521 31FF                        xor di, di
  1013 00000523 B90001                      mov cx, 256
  1014 00000526 B800F0                      mov ax, BIOS_SEG
  1015                                  .fill_all:
  1016 00000529 C705[C904]                  mov word [di], int_dummy
  1017 0000052D 894502                      mov word [di+2], ax        ; segment = F000h
  1018 00000530 83C704                      add di, 4
  1019 00000533 49                          dec cx
  1020 00000534 75F3                        jnz .fill_all
  1021                                  
  1022                                      ; Now overwrite INT 00-1F from the interrupt_table
  1023                                      ; We need to read from CS:interrupt_table. Set up BX as table pointer
  1024                                      ; and use DS=CS temporarily to read, then DS=0 to write.
  1025 00000536 BE[D304]                    mov si, interrupt_table
  1026 00000539 31FF                        xor di, di             ; IVT offset 0
  1027 0000053B B92000                      mov cx, 32
  1028                                  .ivt_copy:
  1029                                      ; Read offset from CS:SI
  1030 0000053E 1E                          push ds
  1031 0000053F 0E                          push cs
  1032 00000540 1F                          pop ds
  1033 00000541 8B1C                        mov bx, [si]           ; BX = handler offset from table
  1034 00000543 1F                          pop ds                 ; DS = 0 again
  1035                                      ; Write to IVT
  1036 00000544 891D                        mov [di], bx           ; offset
  1037 00000546 C7450200F0                  mov word [di+2], BIOS_SEG  ; segment
  1038 0000054B 83C602                      add si, 2
  1039 0000054E 83C704                      add di, 4
  1040 00000551 49                          dec cx
  1041 00000552 75EA                        jnz .ivt_copy
  1042                                  
  1043                                      ; Overwrite INT 20h with int20h_handler
  1044 00000554 C7068000[B204]              mov word [0x20*4], int20h_handler
  1045 0000055A C706820000F0                mov word [0x20*4+2], BIOS_SEG
  1046                                  
  1047                                      ; INT 21h: default_handler (kernel installs its own)
  1048 00000560 C7068400[CA04]              mov word [0x21*4], default_handler
  1049 00000566 C706860000F0                mov word [0x21*4+2], BIOS_SEG
  1050                                  
  1051                                      ; --- Initialize BDA ---
  1052                                      ; (Reference: kbd_buffer_init + individual field setup)
  1053 0000056C B84000                      mov ax, BDA_SEG
  1054 0000056F 8ED8                        mov ds, ax
  1055                                  
  1056                                      ; Equipment list: floppy present + 80x25 color = 0x0021
  1057 00000571 C70610002100                mov word [equipment_list], 0x0021
  1058                                  
  1059                                      ; Memory size: 640 KiB
  1060 00000577 C70613008002                mov word [memory_size], 640
  1061                                  
  1062                                      ; Keyboard buffer initialization (matches kbd_buffer_init)
  1063 0000057D C7061A001E00                mov word [kbd_buffer_head], kbd_buffer   ; 0x001E
  1064 00000583 C7061C001E00                mov word [kbd_buffer_tail], kbd_buffer   ; 0x001E (empty)
  1065 00000589 C70680001E00                mov word [kbd_buffer_start], kbd_buffer  ; 0x001E
  1066 0000058F B81E00                      mov ax, kbd_buffer
  1067 00000592 83C020                      add ax, 0x20                             ; buffer size = 32 bytes
  1068 00000595 A38200                      mov word [kbd_buffer_end], ax            ; 0x003E
  1069                                  
  1070                                      ; Clear keyboard flags
  1071 00000598 C70617000000                mov word [kbd_flags_1], 0       ; flags 1 + flags 2
  1072 0000059E C606190000                  mov byte [kbd_alt_keypad], 0
  1073                                  
  1074                                      ; Video mode and parameters
  1075 000005A3 C606490003                  mov byte [video_mode], 0x03             ; mode 3 = 80x25 text
  1076 000005A8 C7064A005000                mov word [video_columns], 80            ; 80 columns
  1077 000005AE C7064C000010                mov word [video_page_size], 0x1000      ; 4096 bytes per page
  1078 000005B4 C7064E000000                mov word [video_page_offt], 0x0000      ; page 0 offset
  1079 000005BA C70650000000                mov word [video_cur_pos], 0x0000        ; cursor at (0,0)
  1080 000005C0 C70652000000                mov word [video_cur_pos+2], 0x0000      ; page 1 cursor
  1081 000005C6 C70654000000                mov word [video_cur_pos+4], 0x0000      ; page 2 cursor
  1082 000005CC C70656000000                mov word [video_cur_pos+6], 0x0000      ; page 3 cursor
  1083 000005D2 C70660000706                mov word [video_cur_shape], 0x0607      ; cursor shape start=6 end=7
  1084 000005D8 C606620000                  mov byte [video_page], 0x00             ; active page 0
  1085 000005DD C7066300D403                mov word [video_port], 0x03D4           ; CRT controller port (color)
  1086 000005E3 C606840018                  mov byte [video_rows], 24               ; rows minus 1
  1087 000005E8 C70685001000                mov word [video_char_height], 16        ; character height
  1088                                  
  1089                                      ; Timer ticks (start at zero)
  1090 000005EE C7066C000000                mov word [ticks_lo], 0
  1091 000005F4 C7066E000000                mov word [ticks_hi], 0
  1092 000005FA C606700000                  mov byte [new_day], 0
  1093                                  
  1094                                      ; Floppy state
  1095 000005FF C6063E0000                  mov byte [fdc_calib_state], 0
  1096 00000604 C6063F0000                  mov byte [fdc_motor_state], 0
  1097 00000609 C606400000                  mov byte [fdc_motor_tout], 0
  1098 0000060E C606410000                  mov byte [fdc_last_error], 0
  1099                                  
  1100                                      ; Clear warm boot flag
  1101 00000613 C70672000000                mov word [warm_boot], 0
