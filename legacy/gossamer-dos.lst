  1110 00000620 B9D007                      mov cx, 2000
  1111 00000623 B82007                      mov ax, 0x0720
  1112                                  .splash_clr:
  1113 00000626 8905                        mov [di], ax
  1114 00000628 83C702                      add di, 2
  1115 0000062B 49                          dec cx
  1116 0000062C 75F8                        jnz .splash_clr
  1117                                  
  1118                                      ; Write "Gossamer BIOS v1.0" at row 1, col 30 (offset = (1*80+30)*2 = 220)
  1119 0000062E BFDC00                      mov di, 220
  1120 00000631 B40F                        mov ah, 0x0F           ; white on black
  1121 00000633 BE[9C06]                    mov si, splash_title
  1122 00000636 E83000                      call .write_splash_str
  1123                                  
  1124                                      ; "640K conventional memory" at row 3, col 28 (offset = (3*80+28)*2 = 536)
  1125 00000639 BF1802                      mov di, 536
  1126 0000063C BE[AF06]                    mov si, splash_mem
  1127 0000063F E82700                      call .write_splash_str
  1128                                  
  1129                                      ; Update cursor position in BDA to row 5 (below splash)
