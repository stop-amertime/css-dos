{
  "schema": "cart@1",
  "name": "Windows 1.01",
  "description": "Microsoft Windows 1.01 (1985) on real MS-DOS 4.00, CGA 640x200. Boots to the MS-DOS Executive with the original desktop applets on the floppy.",
  "display": {
    "cover": "windows101-79.jpg",
    "playTips": [
      "Use the arrow keys to pick a file in the MS-DOS Executive, then press Enter to run it. CLOCK.EXE is a good first click.",
      "Boot takes a little while - Windows loads about 400 KB from a very honest floppy drive. The Microsoft logo means it's working.",
      "Yes, the mouse works: click a file to select it, double-click to open. CLOCK.EXE is a good first double-click."
    ]
  },
  "preset": "dos-corduroy",
  "memory": {
    "conventional": "640K",
    "gfx": false,
    "textVga": true,
    "cgaGfx": true
  },
  "input": {
