{
  "schema": "cart@1",
  "name": "MS-DOS 4.00",
  "description": "Real MS-DOS 4.00 (Microsoft's MIT-licensed 1988 source), booted from its own boot sector. EDLIN, DEBUG, CHKDSK and friends on the floppy.",
  "display": {
    "accent": "#000982",
    "bullets": [
      "The real thing - IO.SYS, MSDOS.SYS, COMMAND.COM",
      "Boots via its 1988 MSBOOT boot sector",
      "EDLIN - line editor",
      "DEBUG - poke memory",
      "CHKDSK / TREE / MEM",
      "FIND / SORT / MORE / FC / LABEL"
    ]
  },
  "preset": "dos-corduroy",
  "memory": {
    "conventional": "640K",
    "gfx": false,
    "textVga": true
  },
  "disk": {
    "size": "720K",
    "files": [
      { "name": "README.TXT", "source": "README.TXT" },
      { "name": "EDLIN.COM", "source": "EDLIN.COM" },
      { "name": "DEBUG.COM", "source": "DEBUG.COM" },
      { "name": "CHKDSK.COM", "source": "CHKDSK.COM" },
      { "name": "TREE.COM", "source": "TREE.COM" },
      { "name": "MORE.COM", "source": "MORE.COM" },
      { "name": "FIND.EXE", "source": "FIND.EXE" },
      { "name": "SORT.EXE", "source": "SORT.EXE" },
      { "name": "FC.EXE", "source": "FC.EXE" },
      { "name": "LABEL.COM", "source": "LABEL.COM" },
      { "name": "MEM.EXE", "source": "MEM.EXE" }
    ]
  },
  "boot": {
    "os": "msdos4",
    "runCommand": ""
  }
}
