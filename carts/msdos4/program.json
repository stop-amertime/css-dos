      "EDIT - full-screen editor (saves work!)",
      "EDLIN / DEBUG / EXE2BIN - the 1988 toolchain",
      "ATTRIB - unhide IO.SYS and MSDOS.SYS",
      "MODE 40 - big chunky 40-column text",
      "CHKDSK / TREE / MEM / XCOPY / COMP",
      "FIND / SORT / MORE / FC / LABEL"
    ]
  },
